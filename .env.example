# Private key for the account that will deploy the smart contracts
# Hardhat test account #0 — 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
DEPLOYER_PRIVATE_KEY=

# Private key for the account that will act as the relayer
# Hardhat test account #1 — 0x70997970C51812dc3A010C7d01b50e0d17dc79C8
RELAYER_PRIVATE_KEY=

# Address of the relayer account (derived from RELAYER_PRIVATE_KEY)
RELAYER_ADDRESS=

# Private key for a test user account
# Hardhat test account #2 — 0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
USER_A_PRIVATE_KEY=

# Private key for another test user account
# Hardhat test account #3 — 0x90F79bf6EB2c4f870365E785982E1f101E93b906
USER_B_PRIVATE_KEY=

# RPC URL for the Hardhat node (defaults to http://hardhat:8545 inside Docker)
RPC_URL=http://hardhat:8545
